# Neo4j Configuration
# For local Docker: bolt://localhost:7687
# For Neo4j Aura: neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# AI Provider Configuration
# Choose "claude" or "gemini"
AI_PROVIDER=gemini

# Anthropic Claude API Key (if using AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Gemini API Key (if using AI_PROVIDER=gemini)
GOOGLE_API_KEY=xxxxx

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.5-flash

# Microsoft Clarity Project ID
# Get your project ID from https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# Chat Debug Mode
# Set to "true" to enable detailed logging of chat operations to logs/chat-debug.jsonl
CHAT_DEBUG_MODE=false

# App Mode
# Set to "external" for public expo (hides internal features, shows only video segments in chat)
# Set to "internal" for full access to knowledge graph features
NEXT_PUBLIC_APP_MODE=internal
