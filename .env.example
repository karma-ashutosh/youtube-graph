# Neo4j Configuration
# For local Docker: bolt://localhost:7687
# For Neo4j Aura: neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# OpenAI API Key (for concept normalization)
OPENAI_API_KEY=sk-xxxxx

# Or use Google Gemini instead (cheaper/free alternative)
# GOOGLE_API_KEY=xxxxx
