# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control

# GCP Configuration
project_id = "your-gcp-project-id"
region     = "us-central1"

# Service Configuration
service_name = "youtube-graph"
min_instances = 0  # Set to 0 for scale-to-zero cost savings
max_instances = 10

# Resource Limits
cpu_limit    = "1"      # 1 vCPU
memory_limit = "512Mi"  # 512MB RAM (adjust based on your needs)

# Neo4j Configuration
neo4j_uri      = "neo4j+s://xxxxx.databases.neo4j.io"  # Your Neo4j Aura URI
neo4j_user     = "neo4j"
neo4j_password = "your-neo4j-password"

# AI Provider Configuration
ai_provider       = "gemini"  # or "claude"
google_api_key    = "your-google-api-key"
anthropic_api_key = ""  # Only needed if using Claude
gemini_model      = "gemini-2.5-flash"

# Optional Configuration
clarity_project_id = ""  # Microsoft Clarity project ID (optional)
chat_debug_mode    = "false"
app_mode           = "external"  # or "internal"
allow_public_access = true
